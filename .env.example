# Copiar este ficheiro para .env e preencher os valores.
# O .env nunca vai para o git.

# Porta do servidor (opcional; por omissão é 3000)
PORT=3000

# Password para entrar na página de gestão
SENHA_GESTAO=escolher-uma-password

# Texto secreto que protege as sessões (escrever qualquer coisa longa e aleatória)
SEGREDO_SESSAO=escrever-aqui-um-segredo-longo-e-aleatorio